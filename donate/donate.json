{
  "title": "Ủng Hộ JTISVN",
  "meta_tags": {
    "charset": "UTF-8",
    "viewport": "width=device-width, initial-scale=1.0"
  },
  "favicon": "https://raw.githubusercontent.com/jtisvn/jtisvn.github.io/master/icons/favicon.ico",
  "stylesheets": [
    "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap",
    "https://cdn.tailwindcss.com",
    "style.css",
    "https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
  ],
  "body": {
    "class": "bg-gray-900 font-sans text-white min-h-screen",
    "data-theme": "dark",
    "background_elements": [
      {
        "type": "div",
        "class": "background-animation"
      },
      {
        "type": "canvas",
        "id": "raindrop-effect"
      }
    ],
    "components": [
      {
        "type": "div",
        "id": "copy-toast",
        "class": "copy-toast",
        "content": "Đã sao chép!"
      },
      {
        "type": "main_container",
        "class": "main-container mx-auto",
        "content": [
          {
            "type": "main",
            "class": "container mx-auto px-4 py-8",
            "sections": [
              {
                "type": "header_section",
                "class": "flex flex-col items-center justify-center text-center mb-8",
                "nav_bar": {
                  "class": "nav-container",
                  "links": [
                    {
                      "text": "Kho IPA",
                      "href": "https://jtisvn.github.io/homepage/page.html"
                    },
                    {
                      "text": "Repo JTIS",
                      "href": "https://jtisvn.github.io/"
                    },
                    {
                      "text": "Kho Dylib",
                      "href": "https://app.mediafire.com/folder/qlnbgj6n07d14"
                    }
                  ],
                  "theme_toggle_button": {
                    "id": "theme-toggle-btn",
                    "class": "nav-button theme-toggle-button",
                    "icon": "fas fa-sun",
                    "id_icon": "theme-icon"
                  }
                },
                "avatar": {
                  "src": "https://jtisvn.github.io/icons/avatar.webp",
                  "alt": "Avatar",
                  "class": "avatar"
                },
                "titles": {
                  "main_title": {
                    "text": "REPO JTISVN",
                    "class": "text-4xl font-bold shimmering-text"
                  },
                  "description": "Nhận mua hộ Tweak có phí của Havoc và niceOS<br>Ủng hộ cho tôi qua số tài khoản hoặc quét mã QR bên dưới<br> Lưu ý: Nhớ ghi rõ nội dung, mục đích khi thanh toán nha!"
                }
              },
              {
                "type": "social_buttons_section",
                "class": "social-buttons-grid mt-8",
                "buttons": [
                  {
                    "text": "Liên hệ Telegram",
                    "href": "https://t.me/Kitsudo",
                    "class": "social-button telegram-button",
                    "icon": "fab fa-telegram-plane"
                  },
                  {
                    "text": "Liên hệ Facebook",
                    "href": "https://www.facebook.com/hieu.kitsudo?locale=vi_VN",
                    "class": "social-button facebook-button",
                    "icon": "fab fa-facebook-f"
                  }
                ]
              },
              {
                "type": "payment_section",
                "class": "payment-buttons-grid-vertical mt-8",
                "items": [
                  {
                    "type": "payment_item",
                    "class": "payment-item purple-gradient-bg",
                    "content": {
                      "bank_info": {
                        "bank_name": "Ngân hàng TMCP Á Châu",
                        "account_owner": "Chủ TK: NGUYEN TRUNG HIEU",
                        "account_number": {
                          "text": "Số TK: 20219691",
                          "id": "acb-account-number"
                        },
                        "copy_button": {
                          "class": "copy-btn",
                          "onclick": "copyToClipboard('acb-account-number', event)",
                          "icon": "fas fa-copy",
                          "label": "Sao chép"
                        }
                      },
                      "qr_code": {
                        "src": "https://jtisvn.github.io/icons/qr.webp",
                        "alt": "QR Code",
                        "class": "payment-qr-code"
                      }
                    }
                  }
                ]
              },
              {
                "type": "footer_section",
                "class": "text-center mt-12 px-4",
                "thank_you_message": "Sự ủng hộ của bạn là động lực to lớn để JTISVN tiếp tục phát triển. Xin chân thành cảm ơn!"
              }
            ]
          },
          {
            "type": "copyright_container",
            "class": "copyright-container",
            "text": "Copyright © 2025 By: KITSUDO - JTISVN. All rights reserved."
          }
        ]
      }
    ]
  }
}
